<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- Include Spring Boot default configuration -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Property for Correlation ID pattern -->
    <property name="CORRELATION_ID_PATTERN" value="%X{correlationId:-N/A}"/>

    <!-- Console Appender with JSON format -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Custom field for correlation ID -->
            <provider class="net.logstash.logback.composite.loggingevent.MdcJsonProvider"/>
            <customFields>{"application":"hr-management-system","environment":"${SPRING_PROFILES_ACTIVE:-dev}"}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>true</includeContext>
            <includeCallerData>false</includeCallerData>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>version</version>
                <loggerName>logger</loggerName>
                <threadName>thread</threadName>
                <level>level</level>
                <message>message</message>
                <mdc>mdc</mdc>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Console Appender with human-readable format (for dev) -->
    <appender name="CONSOLE_HUMAN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [corr-id:%X{correlationId:-N/A}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root Logger Configuration -->
    <root level="INFO">
        <!-- Use JSON in production, human-readable in dev -->
        <if condition='property("SPRING_PROFILES_ACTIVE").contains("prod")'>
            <then>
                <appender-ref ref="CONSOLE_JSON"/>
            </then>
            <else>
                <appender-ref ref="CONSOLE_HUMAN"/>
            </else>
        </if>
    </root>

    <!-- Application Logger -->
    <logger name="com.hrms" level="DEBUG" additivity="false">
        <if condition='property("SPRING_PROFILES_ACTIVE").contains("prod")'>
            <then>
                <appender-ref ref="CONSOLE_JSON"/>
            </then>
            <else>
                <appender-ref ref="CONSOLE_HUMAN"/>
            </else>
        </if>
    </logger>

    <!-- Spring Security Logger -->
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Web Logger -->
    <logger name="org.springframework.web" level="INFO"/>

</configuration>
